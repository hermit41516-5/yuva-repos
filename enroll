import os
import numpy as np
import librosa
import pickle
from sklearn.mixture import GaussianMixture
from sklearn.preprocessing import StandardScaler
import joblib
import time
import sounddevice as sd
from scipy.io.wavfile import write

SAMPLE_RATE = 16000
DURATION = 4

